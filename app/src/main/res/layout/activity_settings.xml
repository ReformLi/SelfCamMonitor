<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 推流分辨率 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="推流分辨率"
            android:textSize="16sp"
            android:layout_marginTop="12dp" />

        <Spinner
            android:id="@+id/spinnerResolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/resolution_entries" />

        <!-- 推流帧率 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="推流帧率 (fps)"
            android:layout_marginTop="12dp" />

        <SeekBar
            android:id="@+id/seekBarFps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="30"
            android:progress="10" />

        <TextView
            android:id="@+id/tvFpsValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10 fps" />

        <!-- 动作识别阈值 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="动作识别灵敏度 (0-100)"
            android:layout_marginTop="12dp" />

        <SeekBar
            android:id="@+id/seekBarSensitivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50" />

        <TextView
            android:id="@+id/tvSensitivityValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="50" />

        <!-- 开机自启 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="开机自启" />

            <Switch
                android:id="@+id/switchBootStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 报警 URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="报警接收URL"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etAlertUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.1.100:3000/motion" />

        <!-- 报警频率 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="报警静默期(秒)"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etAlertQuiet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="30" />

        <!-- 监控时间限制 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="监控时间限制"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始" />

            <EditText
                android:id="@+id/etStartTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="00:00"
                android:inputType="time" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="结束" />

            <EditText
                android:id="@+id/etEndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="23:59"
                android:inputType="time" />
        </LinearLayout>

        <!-- 用户名 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HTTP认证用户名"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="admin"
            android:inputType="text" />

        <!-- 密码 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HTTP认证密码"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="输入密码"
            android:inputType="textPassword" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="取消"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="保存设置"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>